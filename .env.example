# Copy to .env and adjust. NEVER commit the real .env.
FACECORE_ENV=production

# Device: auto | cuda | cpu
FACECORE_DEVICE=auto

# Model artifacts
FACECORE_MODEL_DIR=./artifacts/models
FACECORE_DETECTOR=retinaface
FACECORE_EMBEDDER=arcface_r100

# Recognition
FACECORE_MATCH_THRESHOLD=0.42      # cosine similarity threshold for a positive ID
FACECORE_DETECT_SCORE_THRESHOLD=0.6
FACECORE_BLUR_THRESHOLD=45.0       # variance-of-Laplacian floor

# Vector store
FACECORE_INDEX_PATH=./artifacts/index/faces.faiss
FACECORE_INDEX_META_PATH=./artifacts/index/faces_meta.json

# API security
FACECORE_API_KEY=change-me-in-real-deployment
FACECORE_MAX_UPLOAD_MB=8
FACECORE_MAX_FACES_PER_IMAGE=20
FACECORE_RATE_LIMIT_PER_MIN=120

# Training
FACECORE_DATA_DIR=./dataset
FACECORE_CHECKPOINT_DIR=./artifacts/checkpoints
FACECORE_TENSORBOARD_DIR=./artifacts/runs
